        layer_Base {
            bindings = <
            &kp EQUAL                         &kp N1                        &kp N2                          &kp N3                              &kp N4  &kp N5                                                                                                                                                                                                          &kp N6                            &kp N7                           &kp N8                         &kp N9                            &kp N0          &kp MINUS
            &kp GRAVE                          &kp Q  &HRM_left_ring_v1_TKZ RALT W                           &kp E                               &kp R   &kp T                                                                                                                                                                                                           &kp Y                             &kp U                            &kp I  &HRM_right_ring_v1_TKZ RALT O                             &kp P  &kp LC(LA(LSHFT))
              &kp ESC  &HRM_left_pinky_v1_TKZ LGUI A  &HRM_left_ring_v1_TKZ LALT S  &HRM_left_middy_v1_TKZ LCTRL D      &HRM_left_index_v1_TKZ LSHFT F   &kp G                                                                                                                                                                                                           &kp H   &HRM_right_index_v1_TKZ RSHFT J  &HRM_right_middy_v1_TKZ RCTRL K  &HRM_right_ring_v1_TKZ LALT L  &HRM_right_pinky_v1_TKZ RGUI SQT            &kp SQT
 &magic LAYER_Magic 0                          &kp Z                         &kp X                           &kp C                               &kp V   &kp B                                                                                                                                                                                                           &kp N                             &kp M                        &kp COMMA                        &kp DOT                          &kp FSLH           &kp RBKT
                                                                          &kp BSLH                        &kp LEFT  &thumb_v2_TKZ LAYER_Navigation ESC                                                                                                                                                                                                                          &thumb_v2_TKZ LAYER_Function DEL                           &kp UP                       &kp FSLH
                                                                                                                                                                &thumb_v2_TKZ LAYER_Navigation SPACE  &thumb_v2_TKZ LAYER_Mouse TAB  &thumb_v2_TKZ LAYER_Mouse TAB  &thumb_v2_TKZ LAYER_Symbols RET  &thumb_v2_TKZ LAYER_Symbols RET  &thumb_v2_TKZ LAYER_Numbers BSPC
            >;
